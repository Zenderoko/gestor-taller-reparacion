# Base de datos (SQLite - archivo local, cero configuración)
DATABASE_URL="file:./dev.db"

# JWT (¡cambiar en producción por una clave segura!)
JWT_SECRET="cambiar-por-clave-segura-aleatoria"
JWT_EXPIRES_IN="7d"

# Entorno: development | production
NODE_ENV=production

# Servidor
PORT=3001

# URL del frontend (para CORS en desarrollo; en producción el frontend lo sirve el backend)
FRONTEND_URL="http://localhost:5173"

# URL base para PDFs y enlaces (cambiar por IP o dominio del servidor)
APP_URL="http://localhost:3001"
